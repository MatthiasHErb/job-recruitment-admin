# Same Supabase project as job-application-erb

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider config for CV analysis
# AI_PROVIDER=openai or infomaniak
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Infomaniak (OpenAI-compatible endpoint)
INFOMANIAK_API_KEY=ik-...
INFOMANIAK_PRODUCT_ID=12345
INFOMANIAK_MODEL=qwen3
